<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>getting_email_ids</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2025/01/09 15:30:10.700</created_date>
    <modified_user>-</modified_user>
    <modified_date>2025/01/09 15:30:10.700</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Get variables-Token-ApiUrl</from>
      <to>Write to log-newHpl</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Write to log-newHpl</from>
      <to>Read Email Ids from DB Table</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Read Email Ids from DB Table</from>
      <to>Copy rows to result</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Copy rows to result</name>
    <type>RowsToResult</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
    <GUI>
      <xloc>784</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Get variables-Token-ApiUrl</name>
    <type>GetVariable</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>4096</length>
        <name>msactoken</name>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <type>String</type>
        <variable>${msactoken}</variable>
      </field>
      <field>
        <length>-1</length>
        <name>apiurl</name>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <type>String</type>
        <variable>${apiurl}</variable>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>112</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Write to log-newHpl</name>
    <type>WriteToLog</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <displayHeader>Y</displayHeader>
    <fields>
      <field>
        <name>msactoken</name>
      </field>
      <field>
        <name>apiurl</name>
      </field>
    </fields>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <loglevel>Basic</loglevel>
    <logmessage>===============
LOG 1 - </logmessage>
    <attributes/>
    <GUI>
      <xloc>336</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Read Email Ids from DB Table</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>hop-samples</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT Email_Ids FROM Emails</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>528</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
